{
	"$schema": "https://app.kilo.ai/config.json",
	"permission": {
		"read": "allow",
		"glob": "allow",
		"grep": "allow",
		"list": "allow",
		"external_directory": "ask",
		"edit": "allow",
		"bash": "allow",
		"skill": "allow",
		"task": "allow"
	},
	"disabled_providers": [],
	"provider": {
		"dmxapi": {
			"name": "DMX",
			"npm": "@ai-sdk/openai-compatible",
			"models": {
				"claude-haiku-4-5-20251001": {
					"name": "Claude Haiku 4.5",
					"limit": {
						"context": 200000,
						"output": 32768,
					},
					"cost": {
						"input": 5,
						"output": 25,
					}
				},
				"claude-sonnet-4-6": {
					"name": "Claude Sonnet 4.6",
					"limit": {
						"context": 200000,
						"output": 32768,
					},
					"cost": {
						"input": 15,
						"output": 75,
					}
				},
				"DMXAPI-CodeX-Free": {
					"name": "DMXAPI-CodeX-Free",
					"limit": {
						"context": 200000,
						"output": 32768,
					},
					"cost": {
						"input": 0,
						"output": 0,
					}
				},
				"DMXAPI-g3-flash-preview": {
					"name": "DMXAPI-g3-flash-preview",
					"limit": {
						"context": 2000000,
						"output": 32768,
					},
					"cost": {
						"input": 2.5,
						"output": 15,
					}
				},
				"glm-5.1-free": {
					"name": "GLM-5 free",
					"limit": {
						"context": 198000,
						"output": 32768,
					},
					"cost": {
						"input": 0,
						"output": 0,
					}
				},
				"gpt-5.4": {
					"name": "GPT-5.4",
					"limit": {
						"context": 1000000,
						"output": 32768,
					},
					"cost": {
						"input": 12.5,
						"output": 75,
					}
				},
				"gpt-5.4-mini": {
					"name": "GPT-5.4-Mini",
					"limit": {
						"context": 400000,
						"output": 32768,
					},
					"cost": {
						"input": 3.75,
						"output": 22.5,
					}
				},
				"gpt-5.4-nano": {
					"name": "GPT-5.4-Nano",
					"limit": {
						"context": 400000,
						"output": 32768,
					},
					"cost": {
						"input": 1,
						"output": 6,
					}
				}
			},
			"options": {
				"baseURL": "https://www.dmxapi.cn/v1"
			}
		}
	},
	"share": "auto",
	"experimental": {
		"batch_tool": true,
		"codebase_search": true,
		"openTelemetry": true
	},
	"compaction": {
		"auto": true,
		"prune": true
	},
	"instructions": [
		"~/.agents/rules/**.md"
	],
	"skills": {
		"paths": [
			"~/.agents/skills/"
		]
	}
}
